# Backend API Keys - Copy this to .env and add your actual keys
ACCUWEATHER_API_KEY=your-accuweather-api-key
MARKET_DATA_API_KEY=your-market-api-key
CHATBOT_API_KEY=your-chatbot-api-key

# API Endpoints
ACCUWEATHER_API_ENDPOINT=http://dataservice.accuweather.com
MARKET_DATA_API_ENDPOINT=https://api.data.gov.in/resource/
CHATBOT_API_ENDPOINT=https://api.sarvam.ai/chat/completions
